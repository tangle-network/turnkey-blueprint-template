# Turnkey API Credentials
# Your API public key from Turnkey dashboard
TURNKEY_API_PUBLIC_KEY=tk1public...

# Your API private key from Turnkey dashboard (keep this secret!)
TURNKEY_API_PRIVATE_KEY=tk1private...

# Your organization ID from Turnkey dashboard
TURNKEY_ORGANIZATION_ID=org_...

# Optional: Example key info for testing (if needed)
# TURNKEY_EXAMPLE_PRIVATE_KEY_ID=key_...
# TURNKEY_EXAMPLE_PUBLIC_KEY=public_key... 